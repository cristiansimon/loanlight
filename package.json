{
  "name": "loan-extractor",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal loan document extraction MVP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
