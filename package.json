    "test": "npm run build && npm run test:compiled",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "express": "^4.21.2",
